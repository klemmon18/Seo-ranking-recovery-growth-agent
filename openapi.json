{
  "openapi": "3.1.0",
  "info": {
    "title": "SEO Snapshot API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://seo-ranking-recovery-growth-agent-five.vercel.app"
    }
  ],
  "paths": {
    "/api/seo-snapshot": {
      "post": {
        "operationId": "getSeoSnapshot",
        "summary": "Get SEO ranking snapshot for a domain",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domain": { "type": "string" },
                  "database": { "type": "string", "default": "us" },
                  "topN": { "type": "integer", "default": 50 }
                },
                "required": ["domain"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SEO snapshot response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "clientDomain": { "type": "string" },
                    "summary": {
                      "type": "object",
                      "properties": {
                        "totalKeywordsAnalyzed": { "type": "number" },
                        "cannibalizationCount": { "type": "number" },
                        "quickWinCount": { "type": "number" },
                        "topDropsCount": { "type": "number" }
                      }
                    },
                    "topDrops": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "keyword": { "type": "string" },
                          "position": { "type": "number" },
                          "volume": { "type": "number" },
                          "url": { "type": "string" },
                          "intentBucket": { "type": "string" }
                        }
                      }
                    },
                    "quickWins": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "keyword": { "type": "string" },
                          "position": { "type": "number" },
                          "url": { "type": "string" },
                          "volume": { "type": "number" },
                          "intentBucket": { "type": "string" },
                          "reason": { "type": "string" }
                        }
                      }
                    },
                    "cannibalizationCases": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "keyword": { "type": "string" },
                          "urls": {
                            "type": "array",
                            "items": { "type": "string" }
                          },
                          "recommendedPrimaryUrl": { "type": "string" },
                          "reason": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
