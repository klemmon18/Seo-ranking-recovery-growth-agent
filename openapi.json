{
  "openapi": "3.1.0",
  "info": {
    "title": "SEO Snapshot API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://your-app.vercel.app"
    }
  ],
  "paths": {
    "/api/seo-snapshot": {
      "post": {
        "operationId": "getSeoSnapshot",
        "summary": "Get SEO ranking snapshot for a domain",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domain": {
                    "type": "string",
                    "description": "Client domain like sjwickcpa.com"
                  },
                  "database": {
                    "type": "string",
                    "default": "us"
                  },
                  "topN": {
                    "type": "integer",
                    "default": 50
                  }
                },
                "required": ["domain"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SEO snapshot response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
